{
  "compilerOptions": {

    // 编译目标与模块

    "target": "ES2022",                  // 编译到 ES2022 标准
    "module": "commonjs",                // 使用 CommonJS 模块 (Node.js)
    "lib": ["ES2022"],                   // 包含的标准库声明


    // 输出配置
    
    "outDir": "./dist",                  // 编译输出目录
    "rootDir": "./",                     // 源码根目录
    "sourceMap": true,                   // 生成 .map 文件，方便调试
    "declaration": true,                 // 生成 .d.ts 类型声明文件
    "removeComments": false,             // 保留注释


    // 严格模式 (TypeScript 核心优势)

    "strict": true,                      // 开启所有严格检查 (推荐!)
    "noImplicitAny": true,               // 禁止隐式 any
    "strictNullChecks": true,            // 严格空值检查
    "strictFunctionTypes": true,         // 严格函数类型检查
    "noUnusedLocals": false,             // 学习阶段：允许未使用的局部变量
    "noUnusedParameters": false,         // 学习阶段：允许未使用的参数
    "noFallthroughCasesInSwitch": true,  // 禁止 switch 穿透


    // 模块解析

    "esModuleInterop": true,             // 允许 import  CommonJS 模块
    "allowSyntheticDefaultImports": true,
    "moduleResolution": "node",          // Node.js 风格模块解析
    "resolveJsonModule": true,           // 允许导入 JSON 文件
    "isolatedModules": true,             // 每个文件独立编译


    // 其他

    "skipLibCheck": true,                // 跳过 .d.ts 检查，加快编译
    "forceConsistentCasingInFileNames": true  // 文件名大小写一致
  },
  "include": [
    "ts_demo1.ts",
    "ts_demo2.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
